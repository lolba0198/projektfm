<div class="main">
    <div class="lewo">
        <div class="srodek-lewo">
            <div class="nav-bar">
                {{#each navButtons}}
                    <a href="/?path={{url}}" class="nav-item-btn">{{name}}</a>
                    {{#unless @last}}<span class="separator">/</span>{{/unless}}
                {{/each}}
            </div>
            <br>
            <button onclick="addFolder()">new folder</button>
            <br><button onclick="addFile()">new file</button>
            <br>
            <form enctype="multipart/form-data" method="POST" action="/handleUpload">
                <input type="hidden" name="root" value="{{currentPath}}">
                <input type="file" name="upload" id="f-input" multiple onchange="zmienNapis()" style="display:none">
                <label for="f-input" class="custom-file-upload">Select files</label>
                <input id="upload-btn" type="submit" value="upload" disabled>
            </form>

            <dialog id="addFolder">
                <form action="/handleForm" method="GET">
                    <input type="hidden" name="root" value="{{currentPath}}">
                    <input class="text" type="text" name="foldername" placeholder="folder name" required> <br>
                    <button type="submit">create</button>
                </form>
                <button onclick="document.getElementById('addFolder').close()">cancel</button>
            </dialog>

            <dialog id="addFile">
                <form action="/handleForm" method="GET">
                    <input type="hidden" name="root" value="{{currentPath}}">
                    <input class="text" type="text" name="filename" placeholder="file name" required> <br>
                    <button type="submit">create</button>
                </form>
                <button onclick="document.getElementById('addFile').close()">cancel</button>
            </dialog>
        </div>
    </div>

    <div class="prawo">
        <div class="prawo-folders">
            <div class="folders"><h3>folders</h3></div>
            <div class="lista-items">
                {{#each folders}}
                <div class="kafelek">
                    <a href="/?path={{targetPath}}" style="text-decoration: none;">
                        <div class="ikona dir">DIR</div>
                    </a>
                    <div class="nazwa">[{{name}}]</div>
                    <a href="/remove?root={{currentRoot}}&name={{name}}" class="usun" onclick="return confirm('Usunąć?')">X</a>
                    <a href="/zip?root={{currentRoot}}&name={{name}}" class="zip-btn">Zip</a>
                    <button class="rename-btn" onclick="renameItem('{{currentRoot}}', '{{name}}')">RN</button>
                </div>
                {{/each}}
            </div>
        </div>

        <div class="prawo-files">
            <div class="files"><h3>files</h3></div>
            <div class="lista-items">
                {{#each files}}
                <div class="kafelek">
                    <div class="ikona file">{{ext}}</div>
                    <div class="nazwa">{{name}}</div>
                    <a href="/remove?root={{currentRoot}}&name={{name}}" class="usun" onclick="return confirm('Usunąć?')">X</a>
                    <a href="/download?root={{currentRoot}}&name={{name}}" class="pobierz">V</a>
                    <button class="rename-btn" onclick="renameItem('{{currentRoot}}', '{{name}}')">RN</button>
                </div>
                {{/each}}
            </div>
        </div>
    </div>
</div>

<script>
    function renameItem(root, oldName) {
        let newName = prompt("Nowa nazwa:", oldName);
        if (newName && newName != oldName) {
            window.location.href = "/rename?root=" + root + "&oldName=" + oldName + "&newName=" + newName;
        }
    }
    function zmienNapis() {
        let inp = document.getElementById("f-input");
        let btn = document.getElementById("upload-btn");
        if (inp.files.length > 0) {
            btn.value = "upload " + inp.files.length + " files";
            btn.disabled = false;
        }
    }
    function addFolder() { document.getElementById("addFolder").showModal(); }
    function addFile() { document.getElementById("addFile").showModal(); }
</script>
